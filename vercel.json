{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "mlb.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/data/(.*)",
      "status": 404
    },
    {
      "src": "/\\.env(.*)",
      "status": 404
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/mlb\\.html",
      "dest": "/index.html"
    },
    {
      "src": "/styles.css",
      "dest": "/styles.css"
    },
    {
      "src": "/mlb.js",
      "dest": "/mlb.js"
    }
  ]
}
